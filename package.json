    "deploy:staging": "git push 5apps_staging master",
    "deploy": "git push 5apps master"
  },
  "dependencies": {
    "moment": "^2.30.1",
    "remotestorage-module-shares": "^2.1.4",
    "remotestorage-widget": "^1.8.1",
