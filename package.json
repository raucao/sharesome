{
  "name": "sharesome",
  "version": "1.5.3",
  "description": "Quickly share files from your remote storage",
  "repository": "https://github.com/skddc/sharesome",
  "license": "AGPL-3.0",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "test": "vite build --mode development && ember test --path dist",
